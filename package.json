  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && node scripts/zip-extension.mjs"
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "@vercel/analytics": "^2.0.1",
    "@xenova/transformers": "^2.17.2"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "vite": "^5.4.10"
  }
}
